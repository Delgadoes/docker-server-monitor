# Intervalo de monitoreo en segundos (por defecto 10)
INTERVALO_MONITOR=10

# CONFIGURACIÓN DE DISCORD (Opcional)
# Pega aquí la URL completa del Webhook de tu canal de Discord
# Ejemplo: DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/12345/abcde
DISCORD_WEBHOOK_URL=

# CONFIGURACIÓN DE TELEGRAM (Opcional)
# 1. Obtén el token creando un bot con @BotFather en Telegram
# 2. Obtén tu Chat ID (puedes usar bots como @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
